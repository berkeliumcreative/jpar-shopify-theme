<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {%- if page_title -%}
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- else -%}
    <link rel="icon" type="image/png" href="{{ 'favicon.png' | asset_url }}">
  {%- endif -%}

  {%- comment -%} Open Graph / Twitter Meta {%- endcomment -%}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | default: shop.name }}">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  {%- if page_image -%}
    <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
  {%- endif -%}
  <meta name="twitter:card" content="summary_large_image">

  {%- comment -%} LTC SquareFace Font {%- endcomment -%}
  <style>
    @font-face {
      font-family: 'LTC SquareFace';
      src: url('https://fonts.cdnfonts.com/s/15580/LTC Squareface.woff') format('woff');
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }
  </style>

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Shopify required {%- endcomment -%}
  {{ content_for_header }}

  <script>document.documentElement.classList.replace('no-js', 'js');</script>
</head>
<body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
  <a href="#main-content" class="skip-link">{{ 'accessibility.skip_to_content' | t }}</a>

  {% sections 'header-group' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {%- comment -%} Cart Drawer {%- endcomment -%}
  {% render 'cart-drawer' %}

  {%- comment -%} Email Popup {%- endcomment -%}
  {% section 'email-popup' %}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
