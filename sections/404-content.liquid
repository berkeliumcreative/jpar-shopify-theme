{% comment %}
  404 Content Section
  Shows a friendly message and "Continue Shopping" button for the 404 page.
{% endcomment %}

<section
  id="not-found-{{ section.id }}"
  class="not-found-content"
  data-section-id="{{ section.id }}"
  data-section-type="404-content"
>
  <div class="not-found__container page-width">
    <div class="not-found__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
        <path d="M8 11h6"/>
      </svg>
    </div>

    <p class="not-found__text">
      {{ section.settings.message | default: "We can't seem to find the page you're looking for. It may have been moved or no longer exists." }}
    </p>

    <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="not-found__cta btn-primary">
      {{ section.settings.button_text | default: 'Continue Shopping' }}
    </a>
  </div>
</section>

<style>
  #not-found-{{ section.id }} {
    padding-top: 0;
    padding-bottom: 8rem;
  }

  #not-found-{{ section.id }} .not-found__container {
    text-align: center;
    max-width: 32rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  #not-found-{{ section.id }} .not-found__icon {
    color: var(--color-border, #d1d5db);
    margin-bottom: 2rem;
  }

  #not-found-{{ section.id }} .not-found__text {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-foreground-muted, #6b7280);
    margin: 0 0 2.5rem;
  }

  #not-found-{{ section.id }} .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary, #c8102e);
    color: #ffffff;
    font-size: 1rem;
    font-weight: 600;
    padding: 1rem 2.5rem;
    border-radius: 0.625rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  #not-found-{{ section.id }} .btn-primary:hover {
    background-color: var(--color-primary-hover, #a50d26);
    transform: translateY(-1px);
  }
</style>

{% schema %}
{
  "name": "404 Content",
  "tag": "section",
  "class": "section-404-content",
  "limit": 1,
  "settings": [
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "We can't seem to find the page you're looking for. It may have been moved or no longer exists."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Continue Shopping"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    }
  ]
}
{% endschema %}
