{% comment %}
  Customer Login Section
  Email + password form with forgot password and register links.
  Uses Shopify's native {% form 'customer_login' %} and {% form 'recover_customer_password' %}.
{% endcomment %}

<section
  id="customer-login-{{ section.id }}"
  class="customer-page"
  data-section-id="{{ section.id }}"
  data-section-type="customer-login"
>
  <div class="customer-login__container page-width">
    {%- comment -%} Login form {%- endcomment -%}
    <div id="customer-login-form" class="customer-login__card">
      <h1 class="customer-login__title">{{ 'customer.login' | t }}</h1>

      {% form 'customer_login' %}
        {%- if form.errors -%}
          <div class="customer-login__errors form-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="form-group">
          <label for="customer-email" class="form-label">{{ 'customer.email' | t }}</label>
          <input
            type="email"
            id="customer-email"
            name="customer[email]"
            class="form-input"
            autocomplete="email"
            autocapitalize="off"
            required
          >
        </div>

        <div class="form-group">
          <label for="customer-password" class="form-label">{{ 'customer.password' | t }}</label>
          <input
            type="password"
            id="customer-password"
            name="customer[password]"
            class="form-input"
            autocomplete="current-password"
            required
          >
        </div>

        <button type="submit" class="btn-primary customer-login__submit">
          {{ 'customer.login' | t }}
        </button>
      {% endform %}

      <div class="customer-login__links">
        <a href="#recover" class="customer-login__link" id="recover-toggle">
          {{ 'customer.forgot_password' | t }}
        </a>
        <a href="{{ routes.account_register_url }}" class="customer-login__link">
          {{ 'customer.register' | t }}
        </a>
      </div>
    </div>

    {%- comment -%} Password recovery form {%- endcomment -%}
    <div id="customer-recover-form" class="customer-login__card customer-login__card--hidden">
      <h1 class="customer-login__title">{{ 'customer.reset_password' | t }}</h1>
      <p class="customer-login__description">We'll send you an email to reset your password.</p>

      {% form 'recover_customer_password' %}
        {%- if form.errors -%}
          <div class="customer-login__errors form-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <div class="customer-login__success" role="status">
            If that email is in our system, you'll receive a password reset link shortly.
          </div>
        {%- endif -%}

        <div class="form-group">
          <label for="recover-email" class="form-label">{{ 'customer.email' | t }}</label>
          <input
            type="email"
            id="recover-email"
            name="email"
            class="form-input"
            autocomplete="email"
            autocapitalize="off"
            required
          >
        </div>

        <button type="submit" class="btn-primary customer-login__submit">
          Submit
        </button>
      {% endform %}

      <div class="customer-login__links">
        <a href="#login" class="customer-login__link" id="login-toggle">
          Back to {{ 'customer.login' | t }}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    var loginForm = document.getElementById('customer-login-form');
    var recoverForm = document.getElementById('customer-recover-form');
    var recoverToggle = document.getElementById('recover-toggle');
    var loginToggle = document.getElementById('login-toggle');

    function showRecover(e) {
      if (e) e.preventDefault();
      loginForm.classList.add('customer-login__card--hidden');
      recoverForm.classList.remove('customer-login__card--hidden');
    }

    function showLogin(e) {
      if (e) e.preventDefault();
      recoverForm.classList.add('customer-login__card--hidden');
      loginForm.classList.remove('customer-login__card--hidden');
    }

    if (recoverToggle) recoverToggle.addEventListener('click', showRecover);
    if (loginToggle) loginToggle.addEventListener('click', showLogin);

    // Show recover form if hash is #recover or if recovery was posted
    if (window.location.hash === '#recover' || recoverForm.querySelector('.customer-login__success')) {
      showRecover();
    }
  })();
</script>

<style>
  #customer-login-{{ section.id }} {
    padding-top: 8rem;
    padding-bottom: 6rem;
    display: flex;
    justify-content: center;
  }

  #customer-login-{{ section.id }} .customer-login__container {
    width: 100%;
    max-width: 28rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  #customer-login-{{ section.id }} .customer-login__card {
    background: var(--color-background, #ffffff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 1rem;
    padding: 2.5rem;
  }

  #customer-login-{{ section.id }} .customer-login__card--hidden {
    display: none;
  }

  #customer-login-{{ section.id }} .customer-login__title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-foreground, #1a1a1a);
    margin: 0 0 0.5rem;
    text-align: center;
  }

  #customer-login-{{ section.id }} .customer-login__description {
    font-size: 0.9375rem;
    color: var(--color-foreground-muted, #6b7280);
    text-align: center;
    margin: 0 0 1.5rem;
  }

  /* Form elements */
  #customer-login-{{ section.id }} .form-group {
    margin-bottom: 1.25rem;
  }

  #customer-login-{{ section.id }} .form-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-foreground, #1a1a1a);
    margin-bottom: 0.375rem;
  }

  #customer-login-{{ section.id }} .form-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    color: var(--color-foreground, #1a1a1a);
    background: var(--color-background, #ffffff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 0.5rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
  }

  #customer-login-{{ section.id }} .form-input:focus {
    border-color: var(--color-primary, #c8102e);
    box-shadow: 0 0 0 3px rgba(200, 16, 46, 0.1);
  }

  #customer-login-{{ section.id }} .btn-primary {
    display: block;
    width: 100%;
    background-color: var(--color-primary, #c8102e);
    color: #ffffff;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.875rem 2rem;
    border-radius: 0.625rem;
    border: none;
    cursor: pointer;
    text-align: center;
    transition: background-color 0.2s ease, transform 0.2s ease;
    margin-top: 1.5rem;
  }

  #customer-login-{{ section.id }} .btn-primary:hover {
    background-color: var(--color-primary-hover, #a50d26);
    transform: translateY(-1px);
  }

  /* Links */
  #customer-login-{{ section.id }} .customer-login__links {
    display: flex;
    justify-content: space-between;
    margin-top: 1.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  #customer-login-{{ section.id }} .customer-login__link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-primary, #c8102e);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  #customer-login-{{ section.id }} .customer-login__link:hover {
    text-decoration: underline;
  }

  /* Errors & Success */
  #customer-login-{{ section.id }} .form-errors {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #991b1b;
    font-size: 0.8125rem;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    margin-bottom: 1.25rem;
  }

  #customer-login-{{ section.id }} .customer-login__success {
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    color: #065f46;
    font-size: 0.8125rem;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    margin-bottom: 1.25rem;
  }
</style>

{% schema %}
{
  "name": "Customer Login",
  "tag": "section",
  "class": "section-customer-login",
  "limit": 1
}
{% endschema %}
