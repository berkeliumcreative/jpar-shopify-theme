{% comment %}
  Customer Reset Password Section
  New password + confirm password form for password reset flow.
  Uses Shopify's native {% form 'reset_customer_password' %}.
{% endcomment %}

<section
  id="customer-reset-{{ section.id }}"
  class="customer-page"
  data-section-id="{{ section.id }}"
  data-section-type="customer-reset-password"
>
  <div class="customer-reset__container page-width">
    <div class="customer-reset__card">
      <h1 class="customer-reset__title">{{ 'customer.reset_password' | t }}</h1>
      <p class="customer-reset__description">Enter your new password below.</p>

      {% form 'reset_customer_password' %}
        {%- if form.errors -%}
          <div class="customer-reset__errors form-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="form-group">
          <label for="reset-password" class="form-label">{{ 'customer.password' | t }}</label>
          <input
            type="password"
            id="reset-password"
            name="customer[password]"
            class="form-input"
            autocomplete="new-password"
            required
          >
        </div>

        <div class="form-group">
          <label for="reset-password-confirm" class="form-label">Confirm Password</label>
          <input
            type="password"
            id="reset-password-confirm"
            name="customer[password_confirmation]"
            class="form-input"
            autocomplete="new-password"
            required
          >
        </div>

        <button type="submit" class="btn-primary customer-reset__submit">
          {{ 'customer.reset_password' | t }}
        </button>
      {% endform %}
    </div>
  </div>
</section>

<style>
  #customer-reset-{{ section.id }} {
    padding-top: 8rem;
    padding-bottom: 6rem;
    display: flex;
    justify-content: center;
  }

  #customer-reset-{{ section.id }} .customer-reset__container {
    width: 100%;
    max-width: 28rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  #customer-reset-{{ section.id }} .customer-reset__card {
    background: var(--color-background, #ffffff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 1rem;
    padding: 2.5rem;
  }

  #customer-reset-{{ section.id }} .customer-reset__title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-foreground, #1a1a1a);
    margin: 0 0 0.5rem;
    text-align: center;
  }

  #customer-reset-{{ section.id }} .customer-reset__description {
    font-size: 0.9375rem;
    color: var(--color-foreground-muted, #6b7280);
    text-align: center;
    margin: 0 0 1.5rem;
  }

  #customer-reset-{{ section.id }} .form-group {
    margin-bottom: 1.25rem;
  }

  #customer-reset-{{ section.id }} .form-label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-foreground, #1a1a1a);
    margin-bottom: 0.375rem;
  }

  #customer-reset-{{ section.id }} .form-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    color: var(--color-foreground, #1a1a1a);
    background: var(--color-background, #ffffff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 0.5rem;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
  }

  #customer-reset-{{ section.id }} .form-input:focus {
    border-color: var(--color-primary, #c8102e);
    box-shadow: 0 0 0 3px rgba(200, 16, 46, 0.1);
  }

  #customer-reset-{{ section.id }} .btn-primary {
    display: block;
    width: 100%;
    background-color: var(--color-primary, #c8102e);
    color: #ffffff;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.875rem 2rem;
    border-radius: 0.625rem;
    border: none;
    cursor: pointer;
    text-align: center;
    transition: background-color 0.2s ease, transform 0.2s ease;
    margin-top: 1.5rem;
  }

  #customer-reset-{{ section.id }} .btn-primary:hover {
    background-color: var(--color-primary-hover, #a50d26);
    transform: translateY(-1px);
  }

  #customer-reset-{{ section.id }} .form-errors {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #991b1b;
    font-size: 0.8125rem;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    margin-bottom: 1.25rem;
  }
</style>

{% schema %}
{
  "name": "Reset Password",
  "tag": "section",
  "class": "section-customer-reset-password",
  "limit": 1
}
{% endschema %}
