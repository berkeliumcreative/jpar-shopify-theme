        {
          "type": "faq",
          "settings": {
            "question": "Do you ship internationally?",
            "answer": "Currently we ship within the US and Canada. International shipping is coming soon. Join our newsletter for updates."
          }
        }
      ]
    }
  ]
}
{% endschema %}
