          }
        },
        {
          "type": "contact_info",
          "settings": {
            "icon": "map-pin",
            "title": "Address",
            "value": "123 Beauty Lane, Los Angeles, CA 90001",
            "href": ""
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "Standard shipping takes 3-5 business days within the US. Express shipping (1-2 business days) is available at checkout."
          }
        },
        {
          "type": "faq",
          "settings": {
