{% comment %}
  Main Cart Section
  Full-page cart fallback for non-drawer cart experience.
  Uses /cart/change.js for AJAX quantity updates.
{% endcomment %}

<section
  id="main-cart-{{ section.id }}"
  class="main-cart customer-page"
  data-section-id="{{ section.id }}"
  data-section-type="main-cart"
>
  <div class="main-cart__container page-width">
    <h1 class="main-cart__title">{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      <p class="main-cart__count">
        {{ 'cart.items_count' | t: count: cart.item_count }}
      </p>

      <form action="/cart" method="post" novalidate class="main-cart__form">
        {%- comment -%} Cart items table {%- endcomment -%}
        <div class="main-cart__table-wrap">
          <table class="main-cart__table">
            <thead>
              <tr>
                <th class="main-cart__th main-cart__th--product" colspan="2">Product</th>
                <th class="main-cart__th main-cart__th--price">Price</th>
                <th class="main-cart__th main-cart__th--quantity">{{ 'products.quantity' | t }}</th>
                <th class="main-cart__th main-cart__th--total">Total</th>
                <th class="main-cart__th main-cart__th--remove">
                  <span class="visually-hidden">{{ 'cart.remove' | t }}</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {%- for item in cart.items -%}
                <tr class="main-cart__item" data-line-index="{{ forloop.index }}">
                  {%- comment -%} Image {%- endcomment -%}
                  <td class="main-cart__cell main-cart__cell--image">
                    <a href="{{ item.url }}" class="main-cart__image-link" aria-label="{{ item.product.title | escape }}">
                      {%- if item.image -%}
                        <img
                          src="{{ item.image | image_url: width: 150 }}"
                          alt="{{ item.image.alt | default: item.product.title | escape }}"
                          width="75"
                          height="75"
                          loading="lazy"
                          class="main-cart__image"
                        >
                      {%- else -%}
                        <div class="main-cart__image-placeholder"></div>
                      {%- endif -%}
                    </a>
                  </td>

                  {%- comment -%} Product info {%- endcomment -%}
                  <td class="main-cart__cell main-cart__cell--info">
                    <a href="{{ item.url }}" class="main-cart__product-title">
                      {{ item.product.title | escape }}
                    </a>
                    {%- unless item.product.has_only_default_variant -%}
                      <p class="main-cart__variant">{{ item.variant.title | escape }}</p>
                    {%- endunless -%}
                  </td>

                  {%- comment -%} Price {%- endcomment -%}
                  <td class="main-cart__cell main-cart__cell--price" data-label="Price">
                    {%- if item.original_price != item.final_price -%}
                      <span class="main-cart__price main-cart__price--compare">
                        {{ item.original_price | money }}
                      </span>
                      <span class="main-cart__price main-cart__price--sale">
                        {{ item.final_price | money }}
                      </span>
                    {%- else -%}
                      <span class="main-cart__price">
                        {{ item.original_price | money }}
                      </span>
                    {%- endif -%}
                  </td>

                  {%- comment -%} Quantity {%- endcomment -%}
                  <td class="main-cart__cell main-cart__cell--quantity" data-label="{{ 'products.quantity' | t }}">
                    <div class="main-cart__quantity">
                      <button
                        type="button"
                        class="main-cart__qty-btn"
                        data-action="decrease"
                        data-line="{{ forloop.index }}"
                        aria-label="Decrease quantity"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/></svg>
                      </button>
                      <input
                        type="number"
                        name="updates[]"
                        value="{{ item.quantity }}"
                        min="0"
                        class="main-cart__qty-input"
                        data-line="{{ forloop.index }}"
                        aria-label="Quantity for {{ item.product.title | escape }}"
                      >
                      <button
                        type="button"
                        class="main-cart__qty-btn"
                        data-action="increase"
                        data-line="{{ forloop.index }}"
                        aria-label="Increase quantity"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                      </button>
                    </div>
                  </td>

                  {%- comment -%} Line total {%- endcomment -%}
                  <td class="main-cart__cell main-cart__cell--total" data-label="Total">
                    {{ item.final_line_price | money }}
                  </td>

                  {%- comment -%} Remove {%- endcomment -%}
                  <td class="main-cart__cell main-cart__cell--remove">
                    <button
                      type="button"
                      class="main-cart__remove-btn"
                      data-action="remove"
                      data-line="{{ forloop.index }}"
                      aria-label="{{ 'cart.remove' | t }} {{ item.product.title | escape }}"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                    </button>
                  </td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>

        {%- comment -%} Cart footer {%- endcomment -%}
        <div class="main-cart__footer">
          <div class="main-cart__subtotal">
            <span class="main-cart__subtotal-label">{{ 'cart.subtotal' | t }}</span>
            <span class="main-cart__subtotal-value">{{ cart.total_price | money }}</span>
          </div>
          <p class="main-cart__tax-note">Shipping & taxes calculated at checkout</p>
          <div class="main-cart__actions">
            <a href="/collections/all" class="main-cart__continue btn-secondary">
              {{ 'cart.continue_shopping' | t }}
            </a>
            <button type="submit" name="checkout" class="main-cart__checkout btn-primary">
              {{ 'cart.checkout' | t }}
            </button>
          </div>
        </div>
      </form>

    {%- else -%}
      {%- comment -%} Empty cart {%- endcomment -%}
      <div class="main-cart__empty">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="main-cart__empty-icon"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
        <p class="main-cart__empty-text">{{ 'cart.empty' | t }}</p>
        <a href="/collections/all" class="main-cart__empty-cta btn-primary">
          {{ 'cart.continue_shopping' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function() {
    var section = document.getElementById('main-cart-{{ section.id }}');
    if (!section) return;

    section.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-action]');
      if (!btn) return;

      var action = btn.dataset.action;
      var line = parseInt(btn.dataset.line, 10);

      if (action === 'remove') {
        updateCart(line, 0);
      } else if (action === 'decrease' || action === 'increase') {
        var input = section.querySelector('.main-cart__qty-input[data-line="' + line + '"]');
        if (!input) return;
        var current = parseInt(input.value, 10) || 0;
        var next = action === 'decrease' ? Math.max(0, current - 1) : current + 1;
        input.value = next;
        updateCart(line, next);
      }
    });

    function updateCart(line, quantity) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: line, quantity: quantity })
      })
      .then(function() { window.location.reload(); })
      .catch(function(err) { console.error('Cart update failed', err); });
    }
  })();
</script>

<style>
  #main-cart-{{ section.id }} {
    padding-top: 8rem;
    padding-bottom: 6rem;
  }

  #main-cart-{{ section.id }} .main-cart__container {
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    max-width: 64rem;
  }

  #main-cart-{{ section.id }} .main-cart__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-foreground, #1a1a1a);
    margin: 0 0 0.5rem;
  }

  #main-cart-{{ section.id }} .main-cart__count {
    font-size: 0.9375rem;
    color: var(--color-foreground-muted, #6b7280);
    margin: 0 0 2rem;
  }

  /* ── Table ─────────────────────────────────────────────── */
  #main-cart-{{ section.id }} .main-cart__table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  #main-cart-{{ section.id }} .main-cart__table {
    width: 100%;
    border-collapse: collapse;
  }

  #main-cart-{{ section.id }} .main-cart__th {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-foreground-muted, #6b7280);
    padding: 0 0 1rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    text-align: left;
    white-space: nowrap;
  }

  #main-cart-{{ section.id }} .main-cart__item {
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  #main-cart-{{ section.id }} .main-cart__cell {
    padding: 1.25rem 0.5rem;
    vertical-align: middle;
  }

  #main-cart-{{ section.id }} .main-cart__cell--image {
    width: 75px;
    padding-right: 1rem;
  }

  #main-cart-{{ section.id }} .main-cart__image {
    width: 75px;
    height: 75px;
    object-fit: cover;
    border-radius: 0.5rem;
    background: var(--color-background-secondary, #faf9f7);
  }

  #main-cart-{{ section.id }} .main-cart__image-placeholder {
    width: 75px;
    height: 75px;
    background: var(--color-background-secondary, #faf9f7);
    border-radius: 0.5rem;
  }

  #main-cart-{{ section.id }} .main-cart__product-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-foreground, #1a1a1a);
    text-decoration: none;
  }

  #main-cart-{{ section.id }} .main-cart__product-title:hover {
    color: var(--color-primary, #c8102e);
  }

  #main-cart-{{ section.id }} .main-cart__variant {
    font-size: 0.8125rem;
    color: var(--color-foreground-muted, #6b7280);
    margin: 0.25rem 0 0;
  }

  #main-cart-{{ section.id }} .main-cart__price {
    font-size: 0.9375rem;
    color: var(--color-foreground, #1a1a1a);
  }

  #main-cart-{{ section.id }} .main-cart__price--compare {
    text-decoration: line-through;
    color: var(--color-foreground-muted, #6b7280);
    margin-right: 0.5rem;
  }

  #main-cart-{{ section.id }} .main-cart__price--sale {
    color: var(--color-primary, #c8102e);
    font-weight: 600;
  }

  /* ── Quantity controls ─────────────────────────────────── */
  #main-cart-{{ section.id }} .main-cart__quantity {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  #main-cart-{{ section.id }} .main-cart__qty-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: none;
    background: transparent;
    color: var(--color-foreground, #1a1a1a);
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  #main-cart-{{ section.id }} .main-cart__qty-btn:hover {
    background-color: var(--color-background-secondary, #faf9f7);
  }

  #main-cart-{{ section.id }} .main-cart__qty-input {
    width: 2.5rem;
    height: 2.25rem;
    text-align: center;
    border: none;
    border-left: 1px solid var(--color-border, #e5e7eb);
    border-right: 1px solid var(--color-border, #e5e7eb);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-foreground, #1a1a1a);
    background: transparent;
    -moz-appearance: textfield;
  }

  #main-cart-{{ section.id }} .main-cart__qty-input::-webkit-outer-spin-button,
  #main-cart-{{ section.id }} .main-cart__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  #main-cart-{{ section.id }} .main-cart__remove-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: none;
    background: transparent;
    color: var(--color-foreground-muted, #6b7280);
    cursor: pointer;
    border-radius: 0.375rem;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  #main-cart-{{ section.id }} .main-cart__remove-btn:hover {
    color: var(--color-primary, #c8102e);
    background-color: rgba(200, 16, 46, 0.06);
  }

  /* ── Footer ────────────────────────────────────────────── */
  #main-cart-{{ section.id }} .main-cart__footer {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-border, #e5e7eb);
    text-align: right;
  }

  #main-cart-{{ section.id }} .main-cart__subtotal {
    display: flex;
    justify-content: flex-end;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  #main-cart-{{ section.id }} .main-cart__subtotal-label {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-foreground, #1a1a1a);
  }

  #main-cart-{{ section.id }} .main-cart__subtotal-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-foreground, #1a1a1a);
  }

  #main-cart-{{ section.id }} .main-cart__tax-note {
    font-size: 0.8125rem;
    color: var(--color-foreground-muted, #6b7280);
    margin: 0 0 1.5rem;
  }

  #main-cart-{{ section.id }} .main-cart__actions {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    flex-wrap: wrap;
  }

  #main-cart-{{ section.id }} .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary, #c8102e);
    color: #ffffff;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.875rem 2rem;
    border-radius: 0.625rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  #main-cart-{{ section.id }} .btn-primary:hover {
    background-color: var(--color-primary-hover, #a50d26);
    transform: translateY(-1px);
  }

  #main-cart-{{ section.id }} .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--color-foreground, #1a1a1a);
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.875rem 2rem;
    border-radius: 0.625rem;
    border: 2px solid var(--color-border, #e5e7eb);
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  #main-cart-{{ section.id }} .btn-secondary:hover {
    border-color: var(--color-foreground, #1a1a1a);
    background-color: var(--color-background-secondary, #faf9f7);
  }

  /* ── Empty cart ─────────────────────────────────────────── */
  #main-cart-{{ section.id }} .main-cart__empty {
    text-align: center;
    padding: 6rem 1rem;
  }

  #main-cart-{{ section.id }} .main-cart__empty-icon {
    color: var(--color-border, #d1d5db);
    margin-bottom: 1.5rem;
  }

  #main-cart-{{ section.id }} .main-cart__empty-text {
    font-size: 1.125rem;
    color: var(--color-foreground-muted, #6b7280);
    margin: 0 0 2rem;
  }

  /* ── Mobile responsive ─────────────────────────────────── */
  @media screen and (max-width: 749px) {
    #main-cart-{{ section.id }} .main-cart__th--price,
    #main-cart-{{ section.id }} .main-cart__th--total,
    #main-cart-{{ section.id }} .main-cart__th--remove {
      display: none;
    }

    #main-cart-{{ section.id }} .main-cart__cell--price,
    #main-cart-{{ section.id }} .main-cart__cell--total {
      display: none;
    }

    #main-cart-{{ section.id }} .main-cart__cell--remove {
      display: none;
    }

    #main-cart-{{ section.id }} .main-cart__actions {
      flex-direction: column;
    }

    #main-cart-{{ section.id }} .main-cart__footer {
      text-align: center;
    }

    #main-cart-{{ section.id }} .main-cart__subtotal {
      justify-content: center;
    }
  }
</style>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section-main-cart",
  "limit": 1
}
{% endschema %}
