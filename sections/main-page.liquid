{% comment %}
  Main Page Section
  Renders the default page.content from the Shopify page editor.
  Used as the body section on the generic page.json template.
{% endcomment %}

<section
  id="main-page-{{ section.id }}"
  class="main-page"
  data-section-id="{{ section.id }}"
  data-section-type="main-page"
>
  <div class="main-page__container page-width">
    <div class="main-page__content prose">
      {{ page.content }}
    </div>
  </div>
</section>

<style>
  #main-page-{{ section.id }} {
    padding-top: 0;
    padding-bottom: 6rem;
  }

  #main-page-{{ section.id }} .main-page__container {
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    max-width: 48rem;
  }

  /* ── Prose typography ─────────────────────────────────── */
  #main-page-{{ section.id }} .prose {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-foreground, #1a1a1a);
  }

  #main-page-{{ section.id }} .prose h1,
  #main-page-{{ section.id }} .prose h2,
  #main-page-{{ section.id }} .prose h3,
  #main-page-{{ section.id }} .prose h4,
  #main-page-{{ section.id }} .prose h5,
  #main-page-{{ section.id }} .prose h6 {
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-foreground, #1a1a1a);
    margin-top: 2em;
    margin-bottom: 0.75em;
  }

  #main-page-{{ section.id }} .prose h1 { font-size: 2rem; }
  #main-page-{{ section.id }} .prose h2 { font-size: 1.625rem; }
  #main-page-{{ section.id }} .prose h3 { font-size: 1.375rem; }
  #main-page-{{ section.id }} .prose h4 { font-size: 1.125rem; }

  #main-page-{{ section.id }} .prose p {
    margin-bottom: 1.5em;
  }

  #main-page-{{ section.id }} .prose a {
    color: var(--color-primary, #c8102e);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  #main-page-{{ section.id }} .prose a:hover {
    color: var(--color-primary-hover, #a50d26);
  }

  #main-page-{{ section.id }} .prose ul,
  #main-page-{{ section.id }} .prose ol {
    padding-left: 1.5em;
    margin-bottom: 1.5em;
  }

  #main-page-{{ section.id }} .prose li {
    margin-bottom: 0.5em;
  }

  #main-page-{{ section.id }} .prose blockquote {
    border-left: 3px solid var(--color-primary, #c8102e);
    padding-left: 1.25rem;
    margin: 2em 0;
    font-style: italic;
    color: var(--color-foreground-muted, #6b7280);
  }

  #main-page-{{ section.id }} .prose img {
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
    margin: 2em 0;
  }

  #main-page-{{ section.id }} .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 2em 0;
  }

  #main-page-{{ section.id }} .prose th,
  #main-page-{{ section.id }} .prose td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    text-align: left;
  }

  #main-page-{{ section.id }} .prose th {
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-foreground-muted, #6b7280);
  }

  #main-page-{{ section.id }} .prose hr {
    border: none;
    border-top: 1px solid var(--color-border, #e5e7eb);
    margin: 3em 0;
  }
</style>

{% schema %}
{
  "name": "Page Content",
  "tag": "section",
  "class": "section-main-page"
}
{% endschema %}
