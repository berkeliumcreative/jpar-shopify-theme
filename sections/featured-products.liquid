{% comment %}
  Featured Products Section
  Responsive product grid powered by a Shopify collection.
  Renders each product via the 'product-card' snippet.
{% endcomment %}

{%- liquid
  assign collection = section.settings.collection
  assign products_limit = section.settings.products_limit | default: 16
  assign heading = section.settings.heading | default: 'Our Products'
  assign subheading = section.settings.subheading | default: 'Discover luxury beauty essentials crafted with clean, natural ingredients.'
  assign label_text = section.settings.label_text | default: 'CURATED COLLECTION'
  assign button_text = section.settings.button_text | default: 'View All Products'
-%}

<section
  id="featured-products-{{ section.id }}"
  class="featured-products"
  data-section-id="{{ section.id }}"
  data-section-type="featured-products"
>
  <div class="featured-products__container page-width">
    {%- comment -%} Section header {%- endcomment -%}
    <div class="featured-products__header">
      {%- if label_text != blank -%}
        <span class="featured-products__label">
          {{ label_text | escape }}
        </span>
      {%- endif -%}

      <h2 class="featured-products__title">
        {%- assign title_words = heading | split: ' ' -%}
        {%- assign last_word_index = title_words.size | minus: 1 -%}
        {%- for word in title_words -%}
          {%- if forloop.index0 == last_word_index -%}
            <span class="text-gradient-rose">{{ word | escape }}</span>
          {%- else -%}
            {{ word | escape }}{{ ' ' }}
          {%- endif -%}
        {%- endfor -%}
      </h2>

      {%- if subheading != blank -%}
        <p class="featured-products__subtitle">
          {{ subheading | escape }}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} Product grid {%- endcomment -%}
    {%- if collection != blank and collection.products.size > 0 -%}
      <div class="featured-products__grid">
        {%- for product in collection.products limit: products_limit -%}
          <div class="featured-products__grid-item">
            {% render 'product-card', product: product %}
          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} View All button {%- endcomment -%}
      <div class="featured-products__footer">
        <a
          href="{{ collection.url }}"
          class="featured-products__view-all button button--outline"
        >
          {{ button_text | escape }}
          <svg
            class="featured-products__arrow-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    {%- else -%}
      <div class="featured-products__empty">
        <p>Select a collection in the theme editor to display products.</p>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #featured-products-{{ section.id }} {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  #featured-products-{{ section.id }} .featured-products__container {
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    max-width: 80rem;
  }

  /* Header */
  #featured-products-{{ section.id }} .featured-products__header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 40rem;
    margin-left: auto;
    margin-right: auto;
  }

  #featured-products-{{ section.id }} .featured-products__label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary, #c8102e);
    margin-bottom: 0.75rem;
  }

  #featured-products-{{ section.id }} .featured-products__title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1rem;
    color: var(--color-foreground, #1a1a1a);
  }

  @media screen and (min-width: 750px) {
    #featured-products-{{ section.id }} .featured-products__title {
      font-size: 2.5rem;
    }
  }

  #featured-products-{{ section.id }} .text-gradient-rose {
    background: linear-gradient(135deg, var(--color-primary, #c8102e), #e8567f);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  #featured-products-{{ section.id }} .featured-products__subtitle {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-foreground-muted, #6b7280);
    margin: 0;
  }

  /* Product Grid */
  #featured-products-{{ section.id }} .featured-products__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media screen and (min-width: 576px) {
    #featured-products-{{ section.id }} .featured-products__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    #featured-products-{{ section.id }} .featured-products__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 1280px) {
    #featured-products-{{ section.id }} .featured-products__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Footer / View All */
  #featured-products-{{ section.id }} .featured-products__footer {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }

  #featured-products-{{ section.id }} .featured-products__view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.025em;
    color: var(--color-foreground, #1a1a1a);
    background: transparent;
    border: 2px solid var(--color-foreground, #1a1a1a);
    border-radius: 0.75rem;
    padding: 0.875rem 2rem;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.25s ease, color 0.25s ease, transform 0.25s ease;
  }

  #featured-products-{{ section.id }} .featured-products__view-all:hover {
    background-color: var(--color-foreground, #1a1a1a);
    color: #ffffff;
    transform: translateY(-1px);
  }

  #featured-products-{{ section.id }} .featured-products__arrow-icon {
    width: 1.25rem;
    height: 1.25rem;
    transition: transform 0.25s ease;
  }

  #featured-products-{{ section.id }} .featured-products__view-all:hover .featured-products__arrow-icon {
    transform: translateX(4px);
  }

  /* Empty state */
  #featured-products-{{ section.id }} .featured-products__empty {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--color-foreground-muted, #6b7280);
    font-size: 0.9375rem;
    border: 2px dashed var(--color-border, #e5e7eb);
    border-radius: 0.75rem;
  }
</style>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "section-featured-products",
  "settings": [
    {
      "type": "text",
      "id": "label_text",
      "label": "Section Label",
      "default": "CURATED COLLECTION"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Products"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover luxury beauty essentials crafted with clean, natural ingredients."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Products to Show",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Products"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
