{% comment %}
  Collection Grid Section — JPAR Cosmetics
  Responsive product grid for collection pages.
  Header with label, gradient title, description.
  Paginated product grid using product-card snippet.
  Uses same responsive breakpoints as featured-products section.
{% endcomment %}

{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 20
  assign label_text = section.settings.label_text | default: 'Our Collection'

  if collection.handle == 'all'
    assign display_title = 'Shop <span class="text-gradient-rose">jpar</span>'
  else
    assign collection_words = collection.title | split: ' '
    assign last_index = collection_words.size | minus: 1
    assign display_title = ''
    for word in collection_words
      if forloop.index0 == last_index
        assign display_title = display_title | append: '<span class="text-gradient-rose">' | append: word | append: '</span>'
      else
        assign display_title = display_title | append: word | append: ' '
      endif
    endfor
    assign display_title = 'Shop ' | append: display_title
  endif
-%}

<section
  id="collection-grid-{{ section.id }}"
  class="collection-grid"
  data-section-id="{{ section.id }}"
  data-section-type="collection-grid"
>
  <div class="collection-grid__container">

    {%- comment -%} Page header {%- endcomment -%}
    <div class="collection-grid__header">
      {%- if label_text != blank -%}
        <span class="collection-grid__label section-label">
          {{ label_text | escape }}
        </span>
      {%- endif -%}

      <h1 class="collection-grid__title">
        {{ display_title }}
      </h1>

      {%- if collection.description != blank -%}
        <p class="collection-grid__desc">
          {{ collection.description | strip_html | truncate: 200 }}
        </p>
      {%- else -%}
        <p class="collection-grid__desc">
          Discover luxury beauty essentials crafted with clean, natural ingredients for radiant skin.
        </p>
      {%- endif -%}
    </div>

    {%- comment -%} Product count + sort (optional) {%- endcomment -%}
    {%- if collection.products.size > 0 -%}
      <div class="collection-grid__toolbar">
        <span class="collection-grid__count">
          {{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}
        </span>
      </div>
    {%- endif -%}

    {%- comment -%} Product grid {%- endcomment -%}
    {%- paginate collection.products by products_per_page -%}
      {%- if collection.products.size > 0 -%}
        <div class="collection-grid__grid">
          {%- for product in collection.products -%}
            <div class="collection-grid__grid-item">
              {% render 'product-card', product: product %}
            </div>
          {%- endfor -%}
        </div>

        {%- comment -%} Pagination {%- endcomment -%}
        {%- if paginate.pages > 1 -%}
          <nav class="collection-grid__pagination" aria-label="Collection pagination">
            <ul class="collection-grid__pagination-list">

              {%- comment -%} Previous {%- endcomment -%}
              {%- if paginate.previous -%}
                <li>
                  <a
                    href="{{ paginate.previous.url }}"
                    class="collection-grid__page-link collection-grid__page-link--prev"
                    aria-label="Previous page"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                    <span>Prev</span>
                  </a>
                </li>
              {%- endif -%}

              {%- comment -%} Page numbers {%- endcomment -%}
              {%- for part in paginate.parts -%}
                <li>
                  {%- if part.is_link -%}
                    <a
                      href="{{ part.url }}"
                      class="collection-grid__page-link"
                      aria-label="Page {{ part.title }}"
                    >
                      {{ part.title }}
                    </a>
                  {%- elsif part.title == paginate.current_page -%}
                    <span
                      class="collection-grid__page-link collection-grid__page-link--current"
                      aria-current="page"
                      aria-label="Page {{ part.title }}, current page"
                    >
                      {{ part.title }}
                    </span>
                  {%- else -%}
                    <span class="collection-grid__page-link collection-grid__page-link--ellipsis">
                      {{ part.title }}
                    </span>
                  {%- endif -%}
                </li>
              {%- endfor -%}

              {%- comment -%} Next {%- endcomment -%}
              {%- if paginate.next -%}
                <li>
                  <a
                    href="{{ paginate.next.url }}"
                    class="collection-grid__page-link collection-grid__page-link--next"
                    aria-label="Next page"
                  >
                    <span>Next</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                </li>
              {%- endif -%}

            </ul>
          </nav>
        {%- endif -%}

      {%- else -%}
        {%- comment -%} Empty collection {%- endcomment -%}
        <div class="collection-grid__empty">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <h2 class="collection-grid__empty-title">No products yet</h2>
          <p class="collection-grid__empty-desc">
            Check back soon for new arrivals.
          </p>
          <a href="/" class="collection-grid__empty-link">
            Back to Home
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      {%- endif -%}
    {%- endpaginate -%}

  </div>
</section>

<style>
  /* ==============================
     Collection Grid — Layout
     ============================== */
  #collection-grid-{{ section.id }} {
    padding-top: calc(var(--header-height, 3.5rem) + 2rem);
    padding-bottom: 4rem;
  }

  @media (min-width: 768px) {
    #collection-grid-{{ section.id }} {
      padding-top: calc(var(--header-height-md, 4rem) + 3rem);
      padding-bottom: 6rem;
    }
  }

  .collection-grid__container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 768px) {
    .collection-grid__container {
      padding: 0 2rem;
    }
  }

  /* ==============================
     Header
     ============================== */
  .collection-grid__header {
    text-align: center;
    margin-bottom: 2.5rem;
    max-width: 40rem;
    margin-left: auto;
    margin-right: auto;
  }

  .collection-grid__label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary, #E02020);
    margin-bottom: 0.75rem;
  }

  .collection-grid__title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.025em;
    color: var(--color-fg, #2E1F1F);
    margin: 0 0 1rem;
  }

  @media (min-width: 768px) {
    .collection-grid__title {
      font-size: 2.5rem;
    }
  }

  .collection-grid__title .text-gradient-rose {
    background: linear-gradient(to right, var(--color-primary, #E02020), var(--color-primary-dark, #B31A1A));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .collection-grid__desc {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-muted, #6B5E5E);
    margin: 0;
  }

  /* ==============================
     Toolbar
     ============================== */
  .collection-grid__toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border, #E8DEDE);
  }

  .collection-grid__count {
    font-size: 0.875rem;
    color: var(--color-muted, #6B5E5E);
    font-weight: 500;
  }

  /* ==============================
     Product Grid
     ============================== */
  .collection-grid__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 576px) {
    .collection-grid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 990px) {
    .collection-grid__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .collection-grid__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ==============================
     Pagination
     ============================== */
  .collection-grid__pagination {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }

  .collection-grid__pagination-list {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .collection-grid__page-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-fg, #2E1F1F);
    text-decoration: none;
    border: 1.5px solid var(--color-border, #E8DEDE);
    border-radius: var(--radius, 0.75rem);
    transition: all 0.2s ease;
  }

  .collection-grid__page-link:hover {
    border-color: var(--color-primary-30, rgba(224, 32, 32, 0.3));
    color: var(--color-primary, #E02020);
  }

  .collection-grid__page-link--current {
    background: var(--color-primary, #E02020);
    color: #fff;
    border-color: var(--color-primary, #E02020);
    font-weight: 600;
  }

  .collection-grid__page-link--current:hover {
    background: var(--color-primary, #E02020);
    color: #fff;
    border-color: var(--color-primary, #E02020);
  }

  .collection-grid__page-link--ellipsis {
    border: none;
    cursor: default;
    min-width: auto;
    padding: 0 0.25rem;
    color: var(--color-muted, #6B5E5E);
  }

  .collection-grid__page-link--prev,
  .collection-grid__page-link--next {
    font-weight: 600;
  }

  .collection-grid__page-link--prev svg,
  .collection-grid__page-link--next svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  /* ==============================
     Empty State
     ============================== */
  .collection-grid__empty {
    text-align: center;
    padding: 5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    border: 2px dashed var(--color-border, #E8DEDE);
    border-radius: var(--radius-xl, 1.25rem);
  }

  .collection-grid__empty svg {
    color: var(--color-muted, #6B5E5E);
    opacity: 0.4;
  }

  .collection-grid__empty-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-fg, #2E1F1F);
    margin: 0;
  }

  .collection-grid__empty-desc {
    font-size: 0.9375rem;
    color: var(--color-muted, #6B5E5E);
    margin: 0;
  }

  .collection-grid__empty-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary, #E02020);
    text-decoration: none;
    margin-top: 0.5rem;
    transition: opacity 0.2s ease;
  }

  .collection-grid__empty-link:hover {
    opacity: 0.8;
  }

  .collection-grid__empty-link svg {
    width: 1rem;
    height: 1rem;
    opacity: 1;
  }
</style>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "class": "section-collection-grid",
  "settings": [
    {
      "type": "text",
      "id": "label_text",
      "label": "Section Label",
      "default": "Our Collection"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 32,
      "step": 4,
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Collection Grid"
    }
  ],
  "templates": ["collection"]
}
{% endschema %}
